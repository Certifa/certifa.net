---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-bottom">
    <div class="footer-id">
      <span class="footer-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 6.5 A8 8 0 1 0 19 17.5"/>
          <path d="M12 8.5 L12 15.5"/>
          <circle cx="16.5" cy="12" r="0.9" fill="currentColor" stroke="none"/>
        </svg>
      </span>
      <span><b>Certifa</b> · offensive security · NL</span>
    </div>
    <div class="footer-links">
      <span>© {year}</span>
      <a href="https://github.com/Certifa" target="_blank" rel="noopener">github</a>
      <a href="https://app.hackthebox.com/users/444744" target="_blank" rel="noopener">hackthebox</a>
      <a href="https://www.linkedin.com/in/mike-bliek-3b319a161/" target="_blank" rel="noopener">linkedin</a>
    </div>
  </div>
</footer>

<style>
  .site-footer { border-top: 1px solid var(--line); }

  .footer-bottom {
    padding: 32px;
    display: flex; justify-content: space-between; align-items: center;
    gap: 16px; flex-wrap: wrap;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--fg-3);
    max-width: 1200px; margin: 0 auto;
  }
  @media (max-width: 700px) { .footer-bottom { padding: 24px 20px; } }

  .footer-bottom b { color: var(--fg); font-weight: 500; }

  .footer-id {
    display: inline-flex; align-items: center; gap: 12px;
  }
  .footer-mark {
    width: 22px; height: 22px;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--accent);
  }
  .footer-mark svg { width: 100%; height: 100%; }

  .footer-links { display: flex; gap: 16px; flex-wrap: wrap; }
  .footer-links a {
    color: var(--fg-2); text-decoration: none;
    transition: color .15s ease;
  }
  .footer-links a:hover { color: var(--accent); }
</style>
