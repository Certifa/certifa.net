---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact" description="Reach out via Discord, GitHub, HackTheBox, email, or LinkedIn.">
  <section class="contact-hero">
    <div class="wrap">
      <div class="page-kicker" data-reveal>/ contact</div>
      <h1 class="contact-title" data-reveal data-reveal-delay="1">Let's <span class="italic">talk.</span></h1>
      <p class="contact-sub" data-reveal data-reveal-delay="2">CTF collabs, internship leads, lab trades, or feedback on a writeup. Pick whichever channel suits you.</p>

      <div class="channels">
        <button class="channel" type="button" data-copy="Quetro" data-reveal>
          <div class="ch-head">
            <span class="ch-key">discord</span>
            <span class="ch-action">Copy ⎘</span>
          </div>
          <div class="ch-val">Quetro</div>
          <div class="ch-note">Fastest way to reach me. DMs open.</div>
        </button>

        <a class="channel" href="https://github.com/Certifa" target="_blank" rel="noopener" data-reveal data-reveal-delay="1">
          <div class="ch-head">
            <span class="ch-key">github</span>
            <span class="ch-action">Visit ↗</span>
          </div>
          <div class="ch-val">github.com/Certifa</div>
          <div class="ch-note">Where the tooling and writeups live.</div>
        </a>

        <a class="channel" href="https://profile.hackthebox.com/profile/019c2f48-7b5d-73a8-b798-3ee811960672" target="_blank" rel="noopener" data-reveal>
          <div class="ch-head">
            <span class="ch-key">hackthebox</span>
            <span class="ch-action">Visit ↗</span>
          </div>
          <div class="ch-val">@certifa</div>
          <div class="ch-note">Master rank · peak Pro Hacker. 50+ machines pwned.</div>
        </a>

        <button class="channel" type="button" data-copy="mike@certifa.net" data-reveal data-reveal-delay="1">
          <div class="ch-head">
            <span class="ch-key">email</span>
            <span class="ch-action">Copy ⎘</span>
          </div>
          <div class="ch-val">mike@certifa.net</div>
          <div class="ch-note">For long-form: teams, collabs, or walls of text.</div>
        </button>

        <a class="channel" href="https://www.linkedin.com/in/mike-bliek-3b319a161/" target="_blank" rel="noopener" data-reveal>
          <div class="ch-head">
            <span class="ch-key">linkedin</span>
            <span class="ch-action">Visit ↗</span>
          </div>
          <div class="ch-val">in/mike-bliek</div>
          <div class="ch-note">For internships and recruiters. CV lives here.</div>
        </a>
      </div>

      <div class="avail" data-reveal>
        <div class="item"><span class="k">Status</span><span class="v ok">Open to messages</span></div>
        <div class="item"><span class="k">Response</span><span class="v">Usually within a day · CET</span></div>
        <div class="item"><span class="k">Looking for</span><span class="v">CTF teams · internships</span></div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px; }
  @media (max-width: 768px) { .wrap { padding: 0 20px; } }

  .contact-hero { padding: 120px 0 80px; }
  @media (max-width: 768px) { .contact-hero { padding: 96px 0 56px; } }

  .contact-title {
    font-family: var(--font-display);
    font-size: clamp(56px, 11vw, 160px);
    font-weight: 600;
    letter-spacing: -0.045em;
    line-height: 0.92;
    margin-bottom: 28px;
  }
  .contact-title .italic {
    font-family: 'Instrument Serif', serif;
    font-style: italic; font-weight: 400;
    color: var(--accent);
  }
  .contact-sub {
    font-size: 19px; color: var(--fg-2);
    max-width: 640px; line-height: 1.6;
    margin-bottom: 72px;
  }
  @media (max-width: 768px) {
    .contact-title { font-size: clamp(44px, 13vw, 56px); }
    .contact-sub { font-size: 17px; margin-bottom: 48px; }
  }

  .channels {
    display: grid; grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-bottom: 60px;
  }
  @media (max-width: 800px) { .channels { grid-template-columns: 1fr; } }

  .channel {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 32px 28px;
    text-decoration: none; color: inherit;
    cursor: pointer;
    font-family: inherit; text-align: left;
    position: relative;
    transition: border-color .2s ease, background .2s ease, transform .2s ease;
  }
  @media (hover: hover) {
    .channel:hover { border-color: var(--line-2); background: var(--bg-3); transform: translateY(-2px); }
  }

  .ch-head {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 24px;
  }
  .ch-key {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--fg-3);
    letter-spacing: 0.12em; text-transform: uppercase;
  }
  .ch-action {
    font-size: 13px; color: var(--fg);
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px; border-radius: 6px;
    border: 1px solid var(--line-2);
    transition: all .2s ease;
  }
  @media (hover: hover) {
    .channel:hover .ch-action { background: var(--accent); color: var(--bg); border-color: var(--accent); }
  }
  .ch-val {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 36px);
    font-weight: 500;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 10px;
    color: var(--fg);
    word-break: break-word;
  }
  .ch-note { color: var(--fg-2); font-size: 14px; line-height: 1.55; }

  .avail {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
  }
  @media (max-width: 800px) { .avail { grid-template-columns: 1fr; } }

  .avail .item { padding: 22px 24px; border-right: 1px solid var(--line); }
  .avail .item:last-child { border-right: none; }
  @media (max-width: 800px) {
    .avail .item { border-right: none; border-bottom: 1px solid var(--line); }
    .avail .item:last-child { border-bottom: none; }
  }
  .avail .k {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--fg-3);
    letter-spacing: 0.12em; text-transform: uppercase;
    margin-bottom: 8px; display: block;
  }
  .avail .v { font-size: 16px; color: var(--fg); }
  .avail .v.ok {
    color: var(--accent);
    display: inline-flex; align-items: center; gap: 10px;
  }
  .avail .v.ok::before {
    content: ''; width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent);
  }
</style>
