</style>

<script>
  // Rotating terminal command + comment
  (() => {
    const line2 = document.getElementById('hmTermLine2');
    const cmt   = document.getElementById('hmTermCommentText');
    if (!line2 || !cmt) return;
    const pairs: [string, string][] = [
      ['cat now.txt',   'studying CCNA · grinding toward 100 boxes'],
      ['ls ~/writeups', 'retired machines only, written up after the flag'],
      ['echo $NEXT',    'CJCA, then CPTS'],
    ];
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      line2.textContent = pairs[0][0];
      cmt.textContent = pairs[0][1];
      return;
    }
    let pi = 0, ci = 0, deleting = false, cmtTimer: number | undefined;
    function showComment(text: string) {
      cmt!.style.transition = 'opacity .35s ease';
      cmt!.style.opacity = '0';
      setTimeout(() => { cmt!.textContent = text; cmt!.style.opacity = '0.55'; }, 360);
    }
    function tick() {
      const [cmd] = pairs[pi];
      if (!deleting) {
        ci++;
        line2!.textContent = cmd.slice(0, ci);
        if (ci === cmd.length) {
          showComment(pairs[pi][1]);
          deleting = true;
          if (cmtTimer) clearTimeout(cmtTimer);
          cmtTimer = window.setTimeout(tick, 2600);
          return;
        }
      } else {
        ci--;
        line2!.textContent = cmd.slice(0, ci);
        if (ci === 0) { deleting = false; pi = (pi + 1) % pairs.length; }
      }
      window.setTimeout(tick, deleting ? 24 : 60 + Math.random() * 55);
    }
    window.setTimeout(tick, 800);
  })();

  // Contact form submit — POST to Cloudflare Worker (forms.certifa.net)
  (() => {
    const form    = document.getElementById('hmContactForm') as HTMLFormElement | null;
    const email   = document.getElementById('hmEmail')       as HTMLInputElement | null;
    const msg     = document.getElementById('hmMsg')         as HTMLTextAreaElement | null;
    const bot     = document.getElementById('hmBotcheck')    as HTMLInputElement | null;
    const btn     = document.getElementById('hmSendBtn')     as HTMLButtonElement | null;
    const errorEl = document.getElementById('hmFormError');
    if (!form || !email || !msg || !bot || !btn || !errorEl) return;

    const ENDPOINT = (location.hostname === 'localhost' || location.hostname === '127.0.0.1')
      ? 'http://localhost:8787/submit'
      : 'https://forms.certifa.net/submit';

    const showError = (text: string) => {
      errorEl!.textContent = text;
      errorEl!.hidden = false;
    };
    const clearError = () => { errorEl!.hidden = true; errorEl!.textContent = ''; };
    const setSubmitting = (on: boolean) => {
      btn!.disabled = on;
      btn!.innerHTML = on ? 'Sending<span class="ar">…</span>' : 'Send <span class="ar">→</span>';
    };
    const showSuccess = () => {
      form!.innerHTML = '<div class="hm-form-success">Got it. I\'ll get back to you.</div>';
    };

    async function send() {
      clearError();

      // Honeypot: filled → silently "succeed" without POSTing
      if (bot!.value.trim() !== '') { showSuccess(); return; }

      const emailVal = email!.value.trim();
      const msgVal   = msg!.value.trim();

      if (!emailVal || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) {
        showError('Need a valid email address.');
        email!.focus();
        return;
      }
      if (msgVal.length < 3) {
        showError('Message needs at least 3 characters.');
        msg!.focus();
        return;
      }

      setSubmitting(true);
      try {
        const res = await fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: emailVal, message: msgVal, botcheck: '' }),
        });
        const data = await res.json().catch(() => ({ ok: false }));
        if (res.ok && data.ok) {
          showSuccess();
        } else {
          setSubmitting(false);
          showError("Something didn't go through. Try again, or email me directly.");
        }
      } catch {
        setSubmitting(false);
        showError("Couldn't reach the server. Check your connection and try again.");
      }
    }

    form.addEventListener('submit', (e) => { e.preventDefault(); send(); });
    msg.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
    });
  })();

  // Heatmap — fetch real HTB activity from /data/heatmap.json
  (async () => {
    const grid    = document.getElementById('hmHeatGrid');
    const totalEl = document.getElementById('hmHeatTotal');
    if (!grid) return;

    type Day = { date: string; count: number };

    // GitHub-style intensity ramp. Low absolute counts (0-5) map directly to
    // levels so a 1-event day looks meaningfully different from a 3-event day.
    function levelFor(c: number): number {
      if (c <= 0) return 0;
      if (c === 1) return 1;
      if (c === 2) return 2;
      if (c <= 4) return 3;
      return 4;
    }

    // Map UTC day-of-week (0=Sun..6=Sat) to row index (0=Mon..6=Sun).
    function dowRow(utcDay: number): number { return (utcDay + 6) % 7; }

    function isoDay(d: Date): string { return d.toISOString().slice(0, 10); }

    function paintGrid(byDate: Map<string, number>, anchor: Date, total: number) {
      grid.innerHTML = '';
      // Layout: 26 columns (calendar weeks) × 7 rows (Mon..Sun).
      // Rightmost column is the week containing `anchor`. Today sits at
      // (col=25, row=dowRow(anchor)). One day passing = one cell shift,
      // never a row reshuffle.
      const cols = 26;
      const rows = 7;

      const anchorRow = dowRow(anchor.getUTCDay());
      // Monday of the rightmost column.
      const colStart = new Date(anchor);
      colStart.setUTCDate(anchor.getUTCDate() - anchorRow);

      for (let r = 0; r < rows; r++) {
        for (let w = 0; w < cols; w++) {
          const cellDate = new Date(colStart);
          cellDate.setUTCDate(colStart.getUTCDate() + (w - (cols - 1)) * 7 + r);

          const iso = isoDay(cellDate);
          const isFuture = cellDate.getTime() > anchor.getTime();
          const count = isFuture ? 0 : (byDate.get(iso) ?? 0);

          const i = document.createElement('i');
          i.dataset.l = String(levelFor(count));
          if (isFuture) {
            i.dataset.future = '1';
            i.title = '';
          } else {
            i.title = `${iso} · ${count} event${count === 1 ? '' : 's'}`;
          }
          grid.appendChild(i);
        }
      }
      if (totalEl) totalEl.textContent = `${total} event${total === 1 ? '' : 's'}`;
    }

    function paint(days: Day[], total: number) {
      const byDate = new Map<string, number>();
      for (const d of days) byDate.set(d.date, d.count);
      // Anchor = real today (UTC). The dataset's keys are also UTC dates, so
      // lookups stay aligned. Days between the dataset's last entry and "now"
      // simply read as level 0 — yesterday's event sits one cell back from
      // today's slot, exactly like GitHub.
      const anchor = new Date();
      anchor.setUTCHours(0, 0, 0, 0);
      paintGrid(byDate, anchor, total);
    }

    function paintEmpty() {
      const anchor = new Date();
      anchor.setUTCHours(0, 0, 0, 0);
      paintGrid(new Map(), anchor, 0);
      if (totalEl) totalEl.textContent = 'no data';
    }

    try {
      const r = await fetch('/data/heatmap.json', { cache: 'no-cache' });
      if (!r.ok) throw new Error(`HTTP ${r.status}`);
      const json = await r.json();
      const days: Day[] = Array.isArray(json?.days) ? json.days : [];
      const total = typeof json?.total === 'number'
        ? json.total
        : days.reduce((s, d) => s + (d.count || 0), 0);
      if (days.length === 0) { paintEmpty(); return; }
      paint(days, total);
    } catch {
      paintEmpty();
    }
  })();
</script>
