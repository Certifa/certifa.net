---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const all = await getCollection('writeups');
const sorted = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latest = sorted[0];
const next3  = sorted.slice(1, 4);

const fmtMon = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { month: 'short', year: '2-digit' })
    .format(d).replace(' ', " '");

const fmtFull = (d: Date) =>
  new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' }).format(d);

const diffNum: Record<string, number> = { easy: 2, medium: 3, hard: 4, insane: 5 };
const glyph = (s: string) => s[0].toUpperCase();

const projects = [
  { icon: '⌘', name: 'AD Home Lab',         tag: 'infra',     desc: 'Server 2022 DC + 2 workstations. The same misconfigs I see on HTB, sitting in my apartment.', stack: ['WS22','Hyper-V','BloodHound'] },
  { icon: '↻', name: 'recon.py',            tag: 'tool',      desc: 'Python pipeline that wraps nmap, ffuf, gobuster, and crackmapexec into a single Markdown report.', stack: ['Python','asyncio','jinja2'] },
  { icon: '▤', name: 'HTB Tracker',         tag: 'dashboard', desc: 'Personal dashboard tracking 50+ boxes: difficulty, time-to-root, recurring techniques, paths.', stack: ['JavaScript','GitHub Pages'] },
  { icon: '◊', name: 'HackTheBox Profile',  tag: 'profile',   desc: 'The proving ground. Every writeup on this site started as a box here.', stack: ['HTB','Pentesting','AD'] },
];
---
<BaseLayout title="Certifa" description="Offensive security student in Utrecht. HackTheBox writeups across Active Directory, Linux, and web.">

  <!-- HERO -->
  <section class="hm-hero">
    <div class="hm-hero-bg" aria-hidden="true"></div>
    <div class="wrap">
      <div class="hm-hero-grid">
        <div class="hm-hero-text">
          <div class="hm-greet" data-reveal><span class="dot"></span>Open to internships &amp; CTF teams</div>
          <h1 class="hm-name" data-reveal data-reveal-delay="1">
            Hi, I'm <span class="accent">Certifa.</span>
          </h1>
          <p class="hm-tag" data-reveal data-reveal-delay="2">
            Offensive security student in Utrecht. I take things apart on <span class="em">HackTheBox</span>, from Active Directory to Linux to web, and write down what I learn.
          </p>
          <div class="hm-cta" data-reveal data-reveal-delay="3">
            <a class="hm-btn primary" href="/writeups/">Read writeups <span class="ar">→</span></a>
            <a class="hm-btn" href="/projects/">See projects</a>
            <a class="hm-btn" href="https://github.com/Certifa" target="_blank" rel="noopener">GitHub <span class="ar">↗</span></a>
          </div>
          <div class="hm-quickstats" data-reveal data-reveal-delay="3">
            <div class="qs"><span class="v">50+</span><span class="k">HTB boxes</span></div>
            <div class="qs"><span class="v">Master</span><span class="k">HTB rank</span></div>
            <div class="qs"><span class="v">Pro Hacker</span><span class="k">peak rank</span></div>
            <div class="qs"><span class="v">{sorted.length}</span><span class="k">writeups</span></div>
          </div>
        </div>

        <!-- TERMINAL CARD -->
        <div class="hm-term" data-reveal data-reveal-delay="2">
          <div class="hm-term-head">
            <div class="tdots"><span></span><span></span><span></span></div>
            <div class="ttitle">~/certifa · zsh</div>
            <div class="tbadge">utc+1</div>
          </div>
          <div class="hm-term-body">
            <div class="hm-term-line"><span class="pr">$</span><span class="cmd">whoami</span></div>
            <div class="hm-term-out">
              <div class="row"><span class="k">name</span><span class="v">Certifa</span></div>
              <div class="row"><span class="k">role</span><span class="v">offsec student</span></div>
              <div class="row"><span class="k">school</span><span class="v">Hogeschool Utrecht</span></div>
              <div class="row"><span class="k">focus</span><span class="v acc">AD · web · privesc</span></div>
              <div class="row"><span class="k">currently</span><span class="v">studying CCNA</span></div>
            </div>
            <hr class="hm-term-rule" />
            <div class="hm-term-line"><span class="pr">$</span><span class="cmd">cat goals.txt</span></div>
            <div class="hm-term-out">
              <div class="row"><span class="arr">→</span>&nbsp;<span class="v">root more boxes (chasing 100)</span></div>
              <div class="row"><span class="arr">→</span>&nbsp;<span class="v">complete more CTFs</span></div>
              <div class="row"><span class="arr">→</span>&nbsp;<span class="v">earn CJCA + CPTS</span></div>
              <div class="row"><span class="arr">→</span>&nbsp;<span class="v">land a red-team internship</span></div>
            </div>
            <hr class="hm-term-rule" />
            <div class="hm-term-line"><span class="pr">$</span><span class="cmd" id="hmTermLine2"></span><span class="cursor"></span></div>
            <div class="hm-term-comment" id="hmTermComment" style="margin-top: 8px;"># <span class="typed" id="hmTermCommentText"></span></div>
            <div class="hm-term-foot">
              <span>utrecht · nl</span>
              <span>parrot · tmux · vim</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WRITEUPS -->
  {latest && (
    <section class="hm-sec">
      <div class="wrap">
        <div class="hm-sec-head" data-reveal>
          <div>
            <h2 class="hm-sec-title">Recent writeups</h2>
            <div class="hm-sec-meta" style="margin-top: 6px;">// retired HTB machines only</div>
          </div>
          <a class="hm-sec-link" href="/writeups/">All {sorted.length} writeups <span class="ar">→</span></a>
        </div>
        <div class="hm-wu-stack">
          <a class="hm-wu featured" href={`/writeups/${latest.slug}/`} data-glyph={glyph(latest.data.title)} data-diff={diffNum[latest.data.difficulty]} data-reveal>
            <div>
              <div class="feat-tag">★ Latest writeup</div>
              <div class="hm-wu-name">{latest.data.title}</div>
              <div class="hm-wu-desc" style="margin-top: 8px;">{latest.data.description}</div>
              <div class="hm-wu-bar" style="margin-top: 18px;"><i></i><i></i><i></i><i></i><i></i></div>
            </div>
            <div class="feat-side">
              <div class="row"><span>platform</span><span class="v">{latest.data.platform}</span></div>
              <div class="row"><span>difficulty</span><span class={`v ${latest.data.difficulty === 'easy' ? 'acc' : ''}`}>{latest.data.difficulty}</span></div>
              <div class="row"><span>filed</span><span class="v">{fmtFull(latest.data.date)}</span></div>
              <div class="row"><span>tags</span><span class="v">{latest.data.tags.slice(0, 2).join(' · ')}</span></div>
              <div style="margin-top:8px; padding-top:14px; border-top:1px solid var(--line); display:flex; justify-content:space-between; align-items:center; color: var(--fg-3);">
                <span>read the post</span>
                <span class="hm-wu-arrow" style="font-size:18px;">→</span>
              </div>
            </div>
          </a>
          <div class="hm-wu-grid">
            {next3.map((w, i) => (
              <a class="hm-wu" href={`/writeups/${w.slug}/`} data-glyph={glyph(w.data.title)} data-diff={diffNum[w.data.difficulty]} data-reveal data-reveal-delay={i}>
                <div class="hm-wu-meta">
                  <span>{fmtMon(w.data.date)}</span>
                  <div class="hm-wu-tags">
                    <span class="hm-wu-tag">{w.data.platform}</span>
                    <span class={`hm-wu-tag diff-${w.data.difficulty}`}>{w.data.difficulty}</span>
                  </div>
                </div>
                <div class="hm-wu-name">{w.data.title}</div>
                <div class="hm-wu-desc">{w.data.description}</div>
                <div class="hm-wu-bar"><i></i><i></i><i></i><i></i><i></i></div>
                <div class="hm-wu-foot">
                  <span>{w.data.tags.slice(0, 3).join(' · ')}</span>
                  <span class="hm-wu-arrow">→</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- PROJECTS -->
  <section class="hm-sec">
    <div class="wrap">
      <div class="hm-sec-head" data-reveal>
        <div>
          <h2 class="hm-sec-title">Things I've built</h2>
          <div class="hm-sec-meta" style="margin-top: 6px;">// labs, tools, dashboards</div>
        </div>
        <a class="hm-sec-link" href="/projects/">All projects <span class="ar">→</span></a>
      </div>
      <div class="hm-pj-list">
        {projects.map((p) => (
          <a class="hm-pj" href="/projects/" data-reveal>
            <div class="hm-pj-icon">{p.icon}</div>
            <div class="hm-pj-text">
              <div class="hm-pj-name">{p.name} <span class="pj-tag">{p.tag}</span></div>
              <div class="hm-pj-desc">{p.desc}</div>
            </div>
            <div class="hm-pj-stack">{p.stack.map((s) => <span>{s}</span>)}</div>
            <div class="hm-pj-arrow">→</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT STRIP + HEATMAP -->
  <section class="hm-sec">
    <div class="wrap">
      <div class="hm-sec-head" data-reveal>
        <div>
          <h2 class="hm-sec-title">A bit about me</h2>
          <div class="hm-sec-meta" style="margin-top: 6px;">// the short version</div>
        </div>
        <a class="hm-sec-link" href="/about/">Full about <span class="ar">→</span></a>
      </div>
      <div class="hm-about-grid">
        <div class="hm-about-text" data-reveal>
          <p>I'm 24, studying <strong>Cybersecurity &amp; Cloud</strong> at <strong>Hogeschool Utrecht</strong>. Most of my free time goes into HackTheBox. The writeups on this site are the boxes that taught me something worth keeping.</p>
          <p>Comfortable across the stack: Kerberos abuse and BloodHound paths in <strong>AD</strong>, weak services and SUID chains on <strong>Linux</strong>, chained logic bugs on the <strong>web</strong>. What interests me is how a few small misconfigs add up to a shell.</p>
          <p>Right now that means CCNA, with CJCA and CPTS lined up after.</p>
          <a class="more" href="/about/">Read more <span class="ar">→</span></a>
        </div>
        <div class="hm-heatmap" data-reveal data-reveal-delay="1">
          <div class="hm-heatmap-head">
            <div class="h-title">Boxes pwned · last 26 weeks</div>
            <div class="h-meta" id="hmHeatTotal">0 rooted</div>
          </div>
          <div class="hm-heatmap-grid" id="hmHeatGrid"></div>
          <div class="hm-heatmap-foot">
            <span>26w ago</span>
            <div class="hm-heatmap-scale">
              <span>less</span>
              <span class="sc" data-l="0"></span>
              <span class="sc" data-l="1"></span>
              <span class="sc" data-l="2"></span>
              <span class="sc" data-l="3"></span>
              <span class="sc" data-l="4"></span>
              <span>more</span>
            </div>
            <span>now</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT STRIP -->
  <section class="hm-contact">
    <div class="wrap">
      <div class="hm-contact-card" data-reveal>
        <div>
          <h3 class="hm-contact-title">Working on something interesting?</h3>
          <p class="hm-contact-sub">CTF teams, internship leads, lab trades, or feedback on a writeup. Pick a channel, they all reach me.</p>
          <div class="hm-contact-channels">
            <a href="mailto:mike@certifa.net"><span class="ic">✉</span>mike@certifa.net</a>
            <a href="https://github.com/Certifa" target="_blank" rel="noopener"><span class="ic">↗</span>github/Certifa</a>
            <a href="https://profile.hackthebox.com/profile/019c2f48-7b5d-73a8-b798-3ee811960672" target="_blank" rel="noopener"><span class="ic">⬢</span>hackthebox</a>
            <a href="https://www.linkedin.com/in/mike-bliek-3b319a161/" target="_blank" rel="noopener"><span class="ic">in</span>linkedin</a>
            <button class="ch-copy" data-copy="Quetro" type="button"><span class="ic">◇</span>discord · Quetro</button>
          </div>
        </div>
        <form class="hm-contact-form" id="hmContactForm" novalidate>
          <div class="field">
            <label for="hmEmail">your email</label>
            <input id="hmEmail" name="email" type="email" required autocomplete="email" placeholder="you@domain.dev" />
          </div>
          <div class="field">
            <label for="hmMsg">one line</label>
            <textarea id="hmMsg" name="message" required minlength="3" placeholder="hey certifa, i'm working on…"></textarea>
          </div>
          <div class="hm-honeypot" aria-hidden="true">
            <label for="hmBotcheck">Don't fill this in</label>
            <input id="hmBotcheck" name="botcheck" type="text" tabindex="-1" autocomplete="off" />
          </div>
          <div class="row">
            <span class="hint" id="hmFormHint">↩ to send</span>
            <button class="hm-btn primary" type="submit" id="hmSendBtn">Send <span class="ar">→</span></button>
          </div>
          <div class="hm-form-error" id="hmFormError" hidden></div>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px; }
  @media (max-width: 768px) { .wrap { padding: 0 20px; } }

  /* HERO */
  .hm-hero {
    padding: clamp(96px, 14vh, 140px) 0 clamp(56px, 9vh, 96px);
    position: relative;
    border-bottom: 1px solid var(--line);
  }
  .hm-hero-bg {
    position: absolute; inset: 0;
    pointer-events: none; overflow: hidden;
    mask-image: radial-gradient(ellipse 75% 60% at 50% 40%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 75% 60% at 50% 40%, black 30%, transparent 80%);
    z-index: 0;
  }
  .hm-hero-bg::before {
    content: ''; position: absolute; inset: -10%;
    background-image: radial-gradient(circle at center, color-mix(in srgb, var(--accent) 35%, transparent) 1px, transparent 1.5px);
    background-size: 28px 28px;
    opacity: 0.18;
    animation: hm-drift 60s linear infinite;
  }
  .hm-hero-bg::after {
    content: ''; position: absolute;
    width: 1px; height: 220px;
    left: 14%; top: -30px;
    background: linear-gradient(180deg, transparent, var(--accent), transparent);
    opacity: 0.55;
    filter: blur(0.5px);
    animation: hm-line-fall 7s ease-in infinite;
  }
  @keyframes hm-drift  { from { transform: translate(0,0); } to { transform: translate(28px, 28px); } }
  @keyframes hm-line-fall {
    0%   { transform: translateY(-260px); opacity: 0; }
    10%  { opacity: 0.55; }
    80%  { opacity: 0.55; }
    100% { transform: translateY(110vh); opacity: 0; }
  }
  .hm-hero > .wrap { position: relative; z-index: 1; }

  .hm-hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 56px;
    align-items: stretch;
  }
  @media (max-width: 920px) { .hm-hero-grid { grid-template-columns: 1fr; gap: 40px; } }

  .hm-hero-text { display: flex; flex-direction: column; justify-content: center; }
  .hm-greet {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11.5px; color: var(--accent);
    letter-spacing: 0.04em; margin-bottom: 22px;
    display: inline-flex; align-items: center; gap: 9px;
    width: max-content;
  }
  .hm-greet .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent);
  }
  .hm-name {
    font-family: 'Geist', sans-serif;
    font-weight: 600;
    font-size: clamp(56px, 8.4vw, 104px);
    line-height: 0.98;
    letter-spacing: -0.04em;
    color: var(--fg);
    margin-bottom: 24px;
  }
  .hm-name .accent { color: var(--accent); }
  @media (max-width: 768px) {
    .hm-name { font-size: clamp(44px, 12vw, 56px); }
  }
  .hm-tag {
    font-size: clamp(18px, 1.7vw, 22px);
    line-height: 1.5;
    color: var(--fg-2);
    max-width: 44ch;
    margin-bottom: 32px;
    text-wrap: pretty;
    letter-spacing: -0.01em;
  }
  .hm-tag .em { color: var(--fg); font-weight: 500; }

  .hm-cta { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }
  .hm-btn {
    font-family: 'Geist', sans-serif;
    font-size: 14px; font-weight: 500;
    padding: 12px 18px;
    border-radius: 10px;
    border: 1px solid var(--line-2);
    background: var(--bg-2);
    color: var(--fg);
    cursor: pointer;
    display: inline-flex; align-items: center; gap: 8px;
    transition: all .18s ease;
    text-decoration: none;
    letter-spacing: -0.005em;
  }
  .hm-btn .ar { transition: transform .2s ease; font-size: 14px; }
  .hm-btn.primary {
    background: var(--accent);
    color: #0a0a0a;
    border-color: var(--accent);
  }
  @media (hover: hover) {
    .hm-btn:hover { background: var(--bg-3); border-color: var(--fg-4); transform: translateY(-1px); }
    .hm-btn:hover .ar { transform: translateX(2px); }
    .hm-btn.primary:hover {
      background: color-mix(in srgb, var(--accent) 88%, white);
      border-color: color-mix(in srgb, var(--accent) 88%, white);
    }
  }

  .hm-quickstats {
    display: flex; gap: 28px; flex-wrap: wrap;
    padding-top: 24px; border-top: 1px solid var(--line);
  }
  .hm-quickstats .qs { display: flex; flex-direction: column; gap: 2px; }
  .hm-quickstats .qs .v {
    font-family: 'Geist', sans-serif;
    font-size: 22px; font-weight: 500;
    color: var(--fg);
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }
  .hm-quickstats .qs .k {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    color: var(--fg-3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* TERMINAL */
  .hm-term {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 30px 60px -30px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.02) inset;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    line-height: 1.7;
    display: flex; flex-direction: column;
    min-height: 460px;
  }
  @media (max-width: 920px) {
    /* Stacked below the hero text — let content size it */
    .hm-term { min-height: 0; }
  }
  .hm-term-head {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 14px;
    background: var(--bg-3);
    border-bottom: 1px solid var(--line);
    flex-shrink: 0;
  }
  .hm-term-head .tdots { display: flex; gap: 6px; }
  .hm-term-head .tdots span { width: 11px; height: 11px; border-radius: 50%; background: var(--line-2); }
  .hm-term-head .tdots span:nth-child(1) { background: #ff5f57; opacity: 0.6; }
  .hm-term-head .tdots span:nth-child(2) { background: #ffbd2e; opacity: 0.6; }
  .hm-term-head .tdots span:nth-child(3) { background: #28c940; opacity: 0.6; }
  .hm-term-head .ttitle { flex: 1; text-align: center; font-size: 11px; color: var(--fg-3); letter-spacing: 0.04em; }
  .hm-term-head .tbadge { font-size: 9.5px; color: var(--fg-3); padding: 2px 7px; border: 1px solid var(--line-2); border-radius: 4px; letter-spacing: 0.06em; }
  .hm-term-body {
    padding: 18px 18px 22px;
    color: var(--fg-2);
    background:
      radial-gradient(ellipse at top right, color-mix(in srgb, var(--accent) 5%, transparent), transparent 60%),
      var(--bg-2);
    flex: 1; display: flex; flex-direction: column;
  }
  .hm-term-line { display: flex; gap: 8px; min-height: 1.7em; }
  .hm-term-line .pr { color: var(--accent); user-select: none; flex-shrink: 0; }
  .hm-term-line .cmd { color: var(--fg); }
  .hm-term-out { color: var(--fg-2); margin: 4px 0 12px; }
  .hm-term-out .row { display: flex; }
  .hm-term-out .k { color: var(--fg-3); display: inline-block; width: 92px; flex-shrink: 0; }
  .hm-term-out .v { color: var(--fg); }
  .hm-term-out .v.acc { color: var(--accent); }
  .hm-term-out .arr { color: var(--fg-3); }
  .hm-term-comment { color: var(--fg-3); font-style: italic; }
  .hm-term .cursor {
    display: inline-block; width: 7px; height: 1em;
    background: var(--accent);
    vertical-align: -2px; margin-left: 2px;
    animation: hm-blink 1.1s steps(1) infinite;
  }
  @keyframes hm-blink { 0%, 50% { opacity: 1; } 50.01%, 100% { opacity: 0; } }
  .hm-term-rule { margin: 4px 0 10px; border: 0; border-top: 1px dashed var(--line-2); }
  .hm-term-foot {
    margin-top: auto; padding-top: 10px;
    display: flex; justify-content: space-between;
    color: var(--fg-3); font-size: 10.5px; letter-spacing: 0.05em;
  }

  /* SECTION HEADERS */
  .hm-sec { padding: 64px 0; border-top: 1px solid var(--line); }
  .hm-sec-head {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 20px; margin-bottom: 32px; flex-wrap: wrap;
  }
  .hm-sec-title {
    font-family: 'Geist', sans-serif;
    font-size: clamp(28px, 3vw, 38px);
    font-weight: 500;
    letter-spacing: -0.025em;
    color: var(--fg);
  }
  .hm-sec-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--fg-3); letter-spacing: 0.06em;
  }
  .hm-sec-link {
    font-size: 14px; color: var(--fg-2);
    background: none; border: 0; padding: 0;
    cursor: pointer; text-decoration: none;
    display: inline-flex; align-items: center; gap: 6px;
    transition: color .2s ease;
  }
  .hm-sec-link .ar { transition: transform .2s ease; }
  @media (hover: hover) {
    .hm-sec-link:hover { color: var(--accent); }
    .hm-sec-link:hover .ar { transform: translateX(3px); }
  }

  /* WRITEUPS — featured + 3-up */
  .hm-wu-stack { display: flex; flex-direction: column; gap: 16px; }
  .hm-wu-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  @media (max-width: 920px) { .hm-wu-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .hm-wu-grid { grid-template-columns: 1fr; } }

