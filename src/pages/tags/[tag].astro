---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTagGroups } from '../../utils/tags';

export async function getStaticPaths() {
  const groups = await getTagGroups();
  return groups.map((g) => ({
    params: { tag: g.slug },
    props: { display: g.display, writeups: g.writeups },
  }));
}

const { display, writeups } = Astro.props;

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).format(d);
---
<BaseLayout title={`#${display}`} description={`Writeups tagged ${display}.`}>
  <section class="page-head">
    <div class="wrap">
      <div class="page-kicker" data-reveal>/ tags</div>
      <h1 class="page-title" data-reveal data-reveal-delay="1"><span class="italic">#{display}</span></h1>
      <p class="page-sub" data-reveal data-reveal-delay="2">
        {writeups.length} writeup{writeups.length === 1 ? '' : 's'} tagged <strong>{display}</strong>.
      </p>
    </div>
  </section>

  <section class="tag-list">
    <div class="wrap">
      <div class="wu-items">
        {writeups.map((w) => (
          <a class="wu-row" href={`/writeups/${w.slug}/`}>
            <div class="wu-main">
              <div class="wu-header-row">
                <span class="wu-name">{w.data.title}</span>
                <span class={`diff-pill diff-${w.data.difficulty}`}>{w.data.difficulty}</span>
                {w.data.featured && <span class="feat-pill">featured</span>}
              </div>
              <div class="wu-desc">{w.data.description}</div>
              <div class="wu-tags">
                {w.data.tags.map((t) => <span class="tag">{t}</span>)}
              </div>
            </div>
            <div class="wu-meta">
              <div class="wu-date">{fmt(w.data.date)}</div>
              <div class="wu-plat">{w.data.platform}</div>
            </div>
          </a>
        ))}
      </div>
      <a class="tag-back" href="/writeups/"><span class="ar">←</span> All writeups</a>
    </div>
  </section>
</BaseLayout>

<style>
  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px; }
  @media (max-width: 768px) { .wrap { padding: 0 20px; } }

  .tag-list { padding: 56px 0 120px; }
  .wu-items { border-top: 1px solid var(--line); }
  .wu-row {
    display: grid; grid-template-columns: 1fr auto; gap: 32px;
    padding: 28px 0; border-bottom: 1px solid var(--line);
    text-decoration: none; color: inherit;
    transition: padding .2s ease, background .2s ease;
    position: relative;
  }
  .wu-row::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 2px; background: var(--accent);
    transform: scaleY(0); transform-origin: center;
    transition: transform .22s ease;
  }
  @media (hover: hover) {
    .wu-row:hover::before { transform: scaleY(1); }
    .wu-row:hover { padding-left: 16px; padding-right: 16px; background: var(--bg-2); }
  }
  @media (max-width: 700px) {
    .wu-row { grid-template-columns: 1fr; gap: 12px; }
  }
  .wu-main { min-width: 0; }
  .wu-header-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 10px; }
  .wu-name {
    font-family: var(--font-display);
    font-size: 28px; font-weight: 500; letter-spacing: -0.025em; line-height: 1;
    color: var(--fg);
  }
  .wu-desc { color: var(--fg-2); font-size: 15px; line-height: 1.55; max-width: 640px; margin-bottom: 12px; }
  .wu-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .wu-meta {
    text-align: right; display: flex; flex-direction: column; align-items: flex-end;
    gap: 10px; padding-top: 6px;
  }
  @media (max-width: 700px) { .wu-meta { text-align: left; align-items: flex-start; } }
  .wu-date { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--fg-3); }
  .wu-plat { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--fg-2); letter-spacing: 0.06em; }

  .tag-back {
    display: inline-flex; align-items: center; gap: 8px;
    margin-top: 32px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; letter-spacing: 0.05em; color: var(--fg-3);
    text-decoration: none; transition: color .15s ease;
  }
  .tag-back .ar { transition: transform .18s ease; }
  @media (hover: hover) {
    .tag-back:hover { color: var(--accent); }
    .tag-back:hover .ar { transform: translateX(-3px); }
  }
</style>
