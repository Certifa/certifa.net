---
import { getCollection } from 'astro:content';
import WriteupLayout from '../../layouts/WriteupLayout.astro';

export async function getStaticPaths() {
  const writeups = await getCollection('writeups');
  return writeups.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();

// Estimate reading time from the prose only. Strip HTML blocks (e.g. the
// locked-writeup notice) so markup and inline styles don't inflate the count.
const words = entry.body
  .replace(/<style[\s\S]*?<\/style>/gi, ' ')
  .replace(/<[^>]+>/g, ' ')
  .split(/\s+/)
  .filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(words / 200));

// Chronological neighbours (newest first) + related writeups by shared tags.
const all = (await getCollection('writeups'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const idx = all.findIndex((w) => w.slug === entry.slug);
const newer = idx > 0 ? all[idx - 1] : null;
const older = idx >= 0 && idx < all.length - 1 ? all[idx + 1] : null;

const related = all
  .filter((w) => w.slug !== entry.slug)
  .map((w) => ({ w, shared: w.data.tags.filter((t) => entry.data.tags.includes(t)).length }))
  .filter((r) => r.shared > 0)
  .sort((a, b) => b.shared - a.shared || b.w.data.date.valueOf() - a.w.data.date.valueOf())
  .slice(0, 3)
  .map((r) => r.w);
---
<WriteupLayout
  entry={entry}
  headings={headings}
  readingTime={readingTime}
  newer={newer}
  older={older}
  related={related}
>
  <Content />
</WriteupLayout>
