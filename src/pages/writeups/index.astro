---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const all = await getCollection('writeups');
const sorted = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }).format(d);

const counts = {
  all:      sorted.length,
  easy:     sorted.filter(w => w.data.difficulty === 'easy').length,
  medium:   sorted.filter(w => w.data.difficulty === 'medium').length,
  hard:     sorted.filter(w => w.data.difficulty === 'hard').length,
  insane:   sorted.filter(w => w.data.difficulty === 'insane').length,
  featured: sorted.filter(w => w.data.featured).length,
};
---
<BaseLayout title="Writeups" description="HackTheBox writeups by Certifa. Retired machines explained start to finish.">
  <section class="page-head">
    <div class="wrap">
      <div class="page-kicker" data-reveal>/ writeups</div>
      <h1 class="page-title" data-reveal data-reveal-delay="1">Notes, after <span class="italic">the flag.</span></h1>
      <p class="page-sub" data-reveal data-reveal-delay="2">Retired HackTheBox machines, documented start to finish: foothold to root, with the reasoning in between.</p>
    </div>
  </section>

  <section class="wu-list">
    <div class="wrap">
      <div class="wu-controls" data-reveal>
        <button class="chip active" data-filter="all">All · {counts.all}</button>
        {counts.easy   > 0 && <button class="chip" data-filter="easy">Easy · {counts.easy}</button>}
        {counts.medium > 0 && <button class="chip" data-filter="medium">Medium · {counts.medium}</button>}
        {counts.hard   > 0 && <button class="chip" data-filter="hard">Hard · {counts.hard}</button>}
        {counts.insane > 0 && <button class="chip" data-filter="insane">Insane · {counts.insane}</button>}
        {counts.featured > 0 && <button class="chip" data-filter="featured">Featured · {counts.featured}</button>}
      </div>

      <div class="wu-items" id="wuItems">
        {sorted.map((w, i) => (
          <a
            class="wu-row"
            href={`/writeups/${w.slug}/`}
            data-difficulty={w.data.difficulty}
            data-featured={w.data.featured ? 'true' : 'false'}
          >
            <div class="wu-num">{String(i + 1).padStart(2, '0')}</div>
            <div class="wu-main">
              <div class="wu-header-row">
                <span class="wu-name">{w.data.title}</span>
                <span class={`diff-pill diff-${w.data.difficulty}`}>{w.data.difficulty}</span>
                {w.data.featured && <span class="feat-pill">featured</span>}
              </div>
              <div class="wu-desc">{w.data.description}</div>
              <div class="wu-tags">
                {w.data.tags.map((t) => <span class="tag">{t}</span>)}
              </div>
            </div>
            <div class="wu-meta">
              <div class="wu-date">{fmt(w.data.date)}</div>
              <div class="wu-plat">{w.data.platform}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px; }
  @media (max-width: 768px) { .wrap { padding: 0 20px; } }

  .wu-list { padding: 72px 0 120px; }
  .wu-controls { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 32px; }

  .wu-items { border-top: 1px solid var(--line); }
  .wu-row {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 32px;
    padding: 28px 0;
    border-bottom: 1px solid var(--line);
    text-decoration: none; color: inherit;
    transition: padding .2s ease, background .2s ease;
    cursor: pointer;
    position: relative;
  }
  .wu-row::before {
    content: ''; position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px; background: var(--accent);
    transform: scaleY(0); transform-origin: center;
    transition: transform .22s ease;
  }
  @media (hover: hover) {
    .wu-row:hover::before { transform: scaleY(1); }
    .wu-row:hover { padding-left: 16px; padding-right: 16px; background: var(--bg-2); }
  }
  @media (max-width: 700px) {
    .wu-row { grid-template-columns: 1fr; gap: 12px; padding: 24px 0; }
    .wu-num { display: none; }
  }
  .wu-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px; color: var(--fg-3);
    padding-top: 6px;
  }
  .wu-main { min-width: 0; }
  .wu-header-row {
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    margin-bottom: 10px;
  }
  .wu-name {
    font-family: 'Geist', sans-serif;
    font-size: 28px; font-weight: 500;
    letter-spacing: -0.025em; line-height: 1;
    color: var(--fg);
  }
  .wu-desc {
    color: var(--fg-2);
    font-size: 15px; line-height: 1.55;
    max-width: 640px;
    margin-bottom: 12px;
  }
  .wu-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .wu-meta {
    text-align: right;
    display: flex; flex-direction: column; align-items: flex-end;
    gap: 10px;
    padding-top: 6px;
  }
  @media (max-width: 700px) { .wu-meta { text-align: left; align-items: flex-start; } }
  .wu-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--fg-3);
  }
  .wu-plat {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--fg-2);
    letter-spacing: 0.06em;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.chip').forEach((c) => {
    c.addEventListener('click', () => {
      document.querySelectorAll('.chip').forEach((x) => x.classList.remove('active'));
      c.classList.add('active');
      const filter = c.getAttribute('data-filter');
      document.querySelectorAll<HTMLElement>('.wu-row').forEach((row) => {
        const diff = row.getAttribute('data-difficulty');
        const feat = row.getAttribute('data-featured') === 'true';
        let show = false;
        if (filter === 'all')           show = true;
        else if (filter === 'featured') show = feat;
        else                            show = diff === filter;
        row.style.display = show ? '' : 'none';
      });
      let n = 1;
      document.querySelectorAll<HTMLElement>('.wu-row').forEach((row) => {
        if (row.style.display === 'none') return;
        const num = row.querySelector('.wu-num');
        if (num) num.textContent = String(n++).padStart(2, '0');
      });
    });
  });
</script>
