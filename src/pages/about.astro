---
import PageLayout from '../layouts/PageLayout.astro';
import Timeline from '../components/Timeline.astro';
---
<PageLayout title="About" label="About" description="Certifa — offensive security, HTB, Active Directory.">
  <div class="px-6 pb-20 max-w-6xl mx-auto">
    <section class="py-12 border-b border-[rgba(255,255,255,0.05)]">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <div class="lg:col-span-3 space-y-5 reveal">
          <p class="text-[#c8cad0] leading-relaxed text-base">
            I'm <span class="text-[#eaedf3] font-semibold">Certifa</span> — a cybersecurity student and offensive security enthusiast studying at Hogeschool Utrecht.
          </p>
          <p class="text-[#c8cad0] leading-relaxed text-base">
            My main playground is HackTheBox. 50+ machines completed, including
            <span class="text-[#eaedf3] font-mono">Insane</span>-rated challenges.
            I work across both Windows and Linux — Kerberos abuse, BloodHound enumeration, and NTLM relay on the Windows side, combined with Linux privesc, web exploitation, and service misconfigurations.
          </p>
          <p class="text-[#c8cad0] leading-relaxed text-base">
            Currently working on: CCNA networking, Python automation tooling, and building out a home lab.
          </p>
          <div class="flex gap-3 pt-2">
            <a href="https://github.com/Certifa" target="_blank" rel="noopener noreferrer" class="btn btn-outline text-sm">GitHub ↗</a>
            <a href="https://app.hackthebox.com/profile/444744" target="_blank" rel="noopener noreferrer" class="btn btn-outline text-sm">HTB Profile ↗</a>
          </div>
        </div>
        <div class="lg:col-span-2 reveal" style="transition-delay:100ms">
          <div class="card p-6">
            <div class="font-sans text-xs text-[#4a4e60] tracking-widest uppercase mb-4">Stats</div>
            <dl class="space-y-3">
              {[
                { label: 'HTB machines', value: '50+' },
                { label: 'Highest difficulty', value: 'Insane' },
                { label: 'Speciality', value: 'Active Directory' },
                { label: 'Attack OS', value: 'Parrot OS' },
              ].map(({ label, value }) => (
                <div class="flex justify-between border-b border-[rgba(255,255,255,0.04)] pb-3 last:border-0 last:pb-0">
                  <dt class="font-sans text-xs text-[#4a4e60]">{label}</dt>
                  <dd class="font-mono text-sm text-[#eaedf3]">{value}</dd>
                </div>
              ))}
            </dl>
          </div>
        </div>
      </div>
    </section>

    <section class="py-12 border-b border-[rgba(255,255,255,0.05)]">
      <div class="reveal mb-8">
        <span class="section-label">Focus</span>
        <h2 class="text-2xl font-bold text-[#eaedf3] mt-1">What I Work On</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { icon: '🏛️', title: 'Active Directory', desc: 'Kerberos attacks, BloodHound, lateral movement, and full domain compromise chains.' },
          { icon: '🌐', title: 'Web Exploitation', desc: 'SQL injection, SSRF, auth bypasses, and chained vulnerabilities via Burp Suite.' },
          { icon: '⬆️', title: 'Privilege Escalation', desc: 'Linux and Windows privesc — weak services, DLL hijacking, token impersonation, kernel exploits.' },
          { icon: '🔐', title: 'Password Attacks', desc: 'Hashcat, Responder, NTLM relay, Pass-the-Hash, and credential hunting.' },
          { icon: '🐍', title: 'Python Automation', desc: 'Scripting recon workflows and building small HTB utilities.' },
          { icon: '🌐', title: 'Networking', desc: 'CCNA study — routing, VLANs, ACLs — and growing interest in cloud pentesting.' },
        ].map((item, i) => (
          <div class="card p-5 reveal" style={`transition-delay:${i*50}ms`}>
            <div class="text-2xl mb-3">{item.icon}</div>
            <h3 class="font-sans font-semibold text-[#eaedf3] text-base mb-2">{item.title}</h3>
            <p class="text-[#9da3b4] text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="py-12">
      <div class="reveal mb-8">
        <span class="section-label">Journey</span>
        <h2 class="text-2xl font-bold text-[#eaedf3] mt-1">Timeline</h2>
      </div>
      <div class="max-w-2xl"><Timeline /></div>
    </section>
  </div>
</PageLayout>
