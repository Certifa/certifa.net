---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  entry: CollectionEntry<'writeups'>;
  headings: MarkdownHeading[];
  readingTime: number;
  newer?: CollectionEntry<'writeups'> | null;
  older?: CollectionEntry<'writeups'> | null;
  related?: CollectionEntry<'writeups'>[];
}

const { entry, headings, readingTime, newer = null, older = null, related = [] } = Astro.props;
const { title, date, tags, difficulty, platform, description } = entry.data;

const fmt = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric',
}).format(date);

const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---
<BaseLayout title={title} description={description} isWriteup={true}>
  <div class="wu-progress" id="wuProgress" aria-hidden="true"></div>
  <article class="wu-page">
    <div class="wrap">
      <a class="wu-back" href="/writeups/">
        <span class="ar">←</span>
        back to writeups
      </a>

      <header class="wu-head">
        <div class="wu-head-meta">
          <span class={`diff-pill diff-${difficulty}`}>{difficulty}</span>
          <span class="wu-plat">{platform}</span>
          <span class="wu-dot">·</span>
          <span class="wu-date">{fmt}</span>
          <span class="wu-dot">·</span>
          <span class="wu-read">~{readingTime} min read</span>
        </div>
        <h1 class="wu-title">{title}</h1>
        <p class="wu-desc">{description}</p>
        <div class="wu-tags">
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      </header>

      <div class="wu-grid">
        <div class="prose-writeup">
          <slot />
        </div>

        {tocHeadings.length > 0 && (
          <aside class="wu-toc-wrap">
            <details class="wu-toc" id="wuToc" open>
              <summary class="wu-toc-title">
                On this page
                <span class="wu-toc-chevron" aria-hidden="true">▾</span>
              </summary>
              <nav class="wu-toc-list">
                {tocHeadings.map((h) => (
                  <a href={`#${h.slug}`} class={`toc-link depth-${h.depth}`}>{h.text}</a>
                ))}
              </nav>
            </details>
          </aside>
        )}
      </div>

      <footer class="wu-end">
        {related.length > 0 && (
          <div class="wu-related">
            <div class="wu-related-label">Related writeups</div>
            <div class="wu-related-grid">
              {related.map((r) => (
                <a class="wu-related-card" href={`/writeups/${r.slug}/`}>
                  <span class={`diff-pill diff-${r.data.difficulty}`}>{r.data.difficulty}</span>
                  <span class="wu-related-name">{r.data.title}</span>
                  <span class="wu-related-tags">{r.data.tags.slice(0, 3).join(' · ')}</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <nav class="wu-prevnext" aria-label="More writeups">
          {older ? (
            <a class="wu-pn older" href={`/writeups/${older.slug}/`}>
              <span class="wu-pn-dir"><span class="ar">←</span> Older</span>
              <span class="wu-pn-name">{older.data.title}</span>
            </a>
          ) : <span class="wu-pn-empty"></span>}
          {newer ? (
            <a class="wu-pn newer" href={`/writeups/${newer.slug}/`}>
              <span class="wu-pn-dir">Newer <span class="ar">→</span></span>
              <span class="wu-pn-name">{newer.data.title}</span>
            </a>
          ) : <span class="wu-pn-empty"></span>}
        </nav>

        <a class="wu-all" href="/writeups/">
          <span class="ar">←</span> All writeups
        </a>
      </footer>
    </div>
  </article>

  <!-- Mermaid: render diagram code blocks client-side (loaded only when a diagram exists) -->
  <script type="module" is:inline>
    const diagrams = document.querySelectorAll('pre[data-language="mermaid"]');
    if (diagrams.length > 0) {
      const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
      mermaid.initialize({
        startOnLoad: false,
        theme: 'base',
        themeVariables: {
          darkMode: true,
          background: '#0a0a0a',
          primaryColor: '#161616',
          primaryTextColor: '#ededed',
          primaryBorderColor: 'rgba(61, 140, 255, 0.35)',
          lineColor: 'rgba(61, 140, 255, 0.85)',
          secondaryColor: '#111111',
          tertiaryColor: '#1f1f1f',
          edgeLabelBackground: '#0a0a0a',
          nodeTextColor: '#ededed',
          clusterBkg: '#111111',
          titleColor: '#ededed',
        },
      });
      for (const pre of diagrams) {
        const code = pre.querySelector('code');
        const text = (code ?? pre).textContent.trim();
        const id = 'mermaid-' + Math.random().toString(36).slice(2, 8);
        try {
          const { svg } = await mermaid.render(id, text);
          const wrapper = document.createElement('div');
          wrapper.className = 'mermaid-diagram';
          wrapper.innerHTML = svg;
          pre.replaceWith(wrapper);
        } catch (e) {}
      }
    }
  </script>

  <script>
    // Wrap tables so wide ones scroll horizontally instead of overflowing the viewport
    document.querySelectorAll('.prose-writeup table').forEach((table) => {
      const wrap = document.createElement('div');
      wrap.className = 'table-wrap';
      table.parentNode?.insertBefore(wrap, table);
      wrap.appendChild(table);
    });

    // TOC: always-open sticky sidebar on desktop, collapsed drawer on mobile
    const toc = document.getElementById('wuToc') as HTMLDetailsElement | null;
    if (toc) {
      const mq = window.matchMedia('(min-width: 1001px)');
      const syncToc = () => { toc.open = mq.matches; };
      syncToc();
      mq.addEventListener('change', syncToc);
      // Collapse after picking a heading on mobile
      toc.querySelectorAll('a').forEach((a) =>
        a.addEventListener('click', () => { if (!mq.matches) toc.open = false; })
      );
    }

    // Copy buttons on code blocks
    document.querySelectorAll('.prose-writeup pre').forEach((pre) => {
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.type = 'button';
      btn.textContent = 'copy';
      btn.addEventListener('click', () => {
        const code = pre.querySelector('code');
        navigator.clipboard.writeText(code?.textContent ?? '').then(() => {
          btn.textContent = 'copied';
          setTimeout(() => (btn.textContent = 'copy'), 1600);
        });
      });
      (pre as HTMLElement).style.position = 'relative';
      pre.appendChild(btn);
    });

    // Active TOC heading via IntersectionObserver
    const headings = document.querySelectorAll<HTMLElement>('.prose-writeup h2, .prose-writeup h3');
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (links.length > 0) {
      const obs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              const id = (e.target as HTMLElement).id;
              links.forEach((l) => {
                l.classList.toggle('active', l.getAttribute('href') === `#${id}`);
              });
            }
          });
        },
        { rootMargin: '-15% 0% -70% 0%', threshold: 0 }
      );
      headings.forEach((h) => obs.observe(h));
    }

    // Reading-progress bar: fraction of the article scrolled past the viewport top
    const bar = document.getElementById('wuProgress');
    const article = document.querySelector('.wu-page');
    if (bar && article) {
      const update = () => {
        const rect = article.getBoundingClientRect();
        const total = rect.height - window.innerHeight;
        const scrolled = total > 0 ? Math.min(1, Math.max(0, -rect.top / total)) : 0;
        bar.style.transform = `scaleX(${scrolled})`;
      };
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
    }

    // Hover anchor links on headings (headings already carry slug ids)
    document.querySelectorAll<HTMLElement>('.prose-writeup h2[id], .prose-writeup h3[id]').forEach((h) => {
      if (h.querySelector('.wu-anchor')) return;
      const a = document.createElement('a');
      a.className = 'wu-anchor';
      a.href = `#${h.id}`;
      a.setAttribute('aria-label', 'Link to this section');
      a.textContent = '#';
      h.appendChild(a);
    });
  </script>
</BaseLayout>

<style>
  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 32px; }
  @media (max-width: 768px) { .wrap { padding: 0 20px; } }

  .wu-page { padding: 100px 0 120px; }
  @media (max-width: 768px) { .wu-page { padding: 88px 0 64px; } }

  .wu-back {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--fg-3);
    letter-spacing: 0.05em;
    text-decoration: none;
    margin-bottom: 40px;
    transition: color .15s ease;
  }
  .wu-back:hover { color: var(--accent); }
  .wu-back .ar { transition: transform .18s ease; }
  .wu-back:hover .ar { transform: translateX(-3px); }

  .wu-head {
    margin-bottom: 56px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--line);
  }
  .wu-head-meta {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    margin-bottom: 24px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; color: var(--fg-3);
  }
  .wu-plat { color: var(--fg-2); letter-spacing: 0.06em; }
  .wu-dot  { color: var(--fg-4); }
  .wu-date { color: var(--fg-3); }
  .wu-read { color: var(--fg-3); }

  .wu-title {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 72px);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1;
    color: var(--fg);
    margin-bottom: 18px;
  }
  .wu-desc {
    font-size: 18px; color: var(--fg-2);
    max-width: 720px; line-height: 1.55;
    margin-bottom: 20px;
  }
  .wu-tags { display: flex; flex-wrap: wrap; gap: 6px; }

  @media (max-width: 768px) {
    .wu-head { margin-bottom: 40px; padding-bottom: 24px; }
    .wu-head-meta { margin-bottom: 16px; row-gap: 6px; }
    .wu-dot { display: none; }
    .wu-title {
      font-size: clamp(30px, 8.5vw, 40px);
      line-height: 1.08;
      margin-bottom: 14px;
    }
    .wu-desc { font-size: 16.5px; }
    .wu-back { margin-bottom: 28px; }
  }

  .wu-grid {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 64px;
    align-items: start;
  }
  @media (max-width: 1000px) {
    .wu-grid { grid-template-columns: 1fr; gap: 32px; }
  }

  .wu-toc-wrap { position: sticky; top: 100px; align-self: start; }
  @media (max-width: 1000px) {
    .wu-toc-wrap { position: static; order: -1; margin-bottom: 12px; }
  }
  .wu-toc {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 18px 18px 16px;
  }
  .wu-toc-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10.5px;
    color: var(--fg-3);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    display: flex; align-items: center; justify-content: space-between;
    list-style: none;
    cursor: default;
    user-select: none;
    pointer-events: none; /* desktop sidebar is not toggleable */
  }
  .wu-toc-title::-webkit-details-marker { display: none; }
  .wu-toc[open] .wu-toc-title { margin-bottom: 12px; }
  .wu-toc-chevron { display: none; }
  @media (max-width: 1000px) {
    .wu-toc { padding: 4px 16px; }
    .wu-toc-title { cursor: pointer; font-size: 11.5px; padding: 14px 0; pointer-events: auto; }
    .wu-toc[open] .wu-toc-title { margin-bottom: 4px; }
    .wu-toc-chevron {
      display: inline-block;
      font-size: 13px;
      transition: transform .18s ease;
    }
    .wu-toc[open] .wu-toc-chevron { transform: rotate(180deg); }
    .wu-toc-list { padding-bottom: 12px; }
  }
  .wu-toc-list { display: flex; flex-direction: column; gap: 2px; }

  /* Reading-progress bar, pinned just under the fixed nav */
  .wu-progress {
    position: fixed; top: 60px; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0); transform-origin: left;
    z-index: 99;
    will-change: transform;
  }

  /* Hover anchor links on headings (created client-side) */
  :global(.prose-writeup h2), :global(.prose-writeup h3) { position: relative; }
  :global(.wu-anchor) {
    position: absolute; left: -1.1em; top: 0;
    color: var(--fg-4); text-decoration: none; font-weight: 400;
    opacity: 0; transition: opacity .15s ease, color .15s ease;
  }
  :global(.wu-anchor:hover) { color: var(--accent); }
  :global(.wu-anchor:focus-visible) { opacity: 1; color: var(--accent); }
  @media (hover: hover) {
    :global(.prose-writeup h2:hover .wu-anchor),
    :global(.prose-writeup h3:hover .wu-anchor) { opacity: 1; }
  }

  /* End-of-writeup: related + prev/next + all-writeups */
  .wu-end {
    margin-top: 72px;
    padding-top: 32px;
    border-top: 1px solid var(--line);
  }
  .wu-related { margin-bottom: 40px; }
  .wu-related-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--fg-3); margin-bottom: 16px;
  }
  .wu-related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  @media (max-width: 760px) { .wu-related-grid { grid-template-columns: 1fr; } }
  .wu-related-card {
    display: flex; flex-direction: column; gap: 10px;
    background: var(--bg-2); border: 1px solid var(--line);
    border-radius: 10px; padding: 16px 18px;
    text-decoration: none; color: inherit;
    transition: border-color .2s ease, background .2s ease, transform .2s ease;
  }
  @media (hover: hover) {
    .wu-related-card:hover { border-color: var(--line-2); background: var(--bg-3); transform: translateY(-2px); }
  }
  .wu-related-card .diff-pill { align-self: flex-start; }
  .wu-related-name {
    font-family: var(--font-display);
    font-size: 18px; font-weight: 500; letter-spacing: -0.015em; color: var(--fg);
  }
  .wu-related-tags {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; color: var(--fg-3); letter-spacing: 0.03em;
  }

  .wu-prevnext { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 28px; }
  @media (max-width: 560px) { .wu-prevnext { grid-template-columns: 1fr; } }
  .wu-pn {
    display: flex; flex-direction: column; gap: 6px;
    background: var(--bg-2); border: 1px solid var(--line);
    border-radius: 10px; padding: 16px 18px;
    text-decoration: none; color: inherit;
    transition: border-color .2s ease, background .2s ease;
  }
  .wu-pn.newer { text-align: right; align-items: flex-end; }
  @media (hover: hover) {
    .wu-pn:hover { border-color: var(--line-2); background: var(--bg-3); }
    .wu-pn:hover .ar { color: var(--accent); }
  }
  .wu-pn-dir {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--fg-3);
    display: inline-flex; align-items: center; gap: 6px;
  }
  .wu-pn .ar { transition: color .2s ease, transform .2s ease; }
  .wu-pn-name { font-size: 15px; color: var(--fg); font-weight: 500; letter-spacing: -0.01em; }
  .wu-pn-empty { display: none; }
  @media (min-width: 561px) { .wu-pn-empty { display: block; } }

  .wu-all {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px; letter-spacing: 0.05em; color: var(--fg-3);
    text-decoration: none;
    transition: color .15s ease;
  }
  .wu-all .ar { transition: transform .18s ease; }
  @media (hover: hover) {
    .wu-all:hover { color: var(--accent); }
    .wu-all:hover .ar { transform: translateX(-3px); }
  }

  .mermaid-diagram {
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 1.5rem;
    margin: 1.5rem 0;
    overflow-x: auto;
    text-align: center;
  }
  .mermaid-diagram svg { max-width: 100%; height: auto; }
</style>
